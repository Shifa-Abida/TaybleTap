{
  "info": {
    "name": "TaybleTap Smart Ordering API",
    "description": "API Documentation for TaybleTap Smart Restaurant Ordering System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "item_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "order_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "table_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Register Restaurant",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/auth/register/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register", ""]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Restaurant\",\n  \"email\": \"test@restaurant.com\",\n  \"phone\": \"+91 9876543210\",\n  \"password\": \"test123\",\n  \"restaurant_name\": \"Test Kitchen\",\n  \"city\": \"Bangalore\",\n  \"restaurant_type\": \"Cloud Kitchen\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login", ""]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@restaurant.com\",\n  \"password\": \"test123\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/auth/me/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/api/auth/profile/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "profile", ""]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurant_name\": \"Updated Kitchen\",\n  \"city\": \"Mysore\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2. Menu Management",
      "item": [
        {
          "name": "List Menu Items",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/menu/",
              "host": ["{{base_url}}"],
              "path": ["api", "menu", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Create Menu Item",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/menu/",
              "host": ["{{base_url}}"],
              "path": ["api", "menu", ""]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Chicken Biryani\",\n  \"price\": 280,\n  \"category\": \"Biryani\",\n  \"desc\": \"Aromatic basmati rice with tender chicken\",\n  \"emoji\": \"🍚\",\n  \"available\": true\n}"
            }
          }
        },
        {
          "name": "Get Menu Item",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/menu/{{item_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "menu", "{{item_id}}", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Update Menu Item",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/api/menu/{{item_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "menu", "{{item_id}}", ""]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Chicken Biryani - Premium\",\n  \"price\": 320,\n  \"category\": \"Biryani\",\n  \"desc\": \"Premium aromatic basmati rice\",\n  \"available\": true\n}"
            }
          }
        },
        {
          "name": "Toggle Availability",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/api/menu/{{item_id}}/toggle/",
              "host": ["{{base_url}}"],
              "path": ["api", "menu", "{{item_id}}", "toggle", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Delete Menu Item",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/menu/{{item_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "menu", "{{item_id}}", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "3. Orders",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/orders/",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "List Orders (Filtered)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/orders/?status=Pending",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", ""],
              "query": [
                {
                  "key": "status",
                  "value": "Pending"
                }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Create Order (Authenticated)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/orders/",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", ""]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"table\": 1,\n  \"items\": [\n    { \"name\": \"Chicken Biryani\", \"price\": 280, \"qty\": 2 },\n    { \"name\": \"Mango Lassi\", \"price\": 90, \"qty\": 1 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Create Order (Guest)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/orders/",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", ""]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"table\": 2,\n  \"items\": [\n    { \"name\": \"Paneer Masala\", \"price\": 220, \"qty\": 1 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get Order Details",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/orders/{{order_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", "{{order_id}}", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/api/orders/{{order_id}}/status/",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", "{{order_id}}", "status", ""]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Accepted\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "4. Tables & QR Codes",
      "item": [
        {
          "name": "List Tables",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/tables/",
              "host": ["{{base_url}}"],
              "path": ["api", "tables", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Create Table",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/tables/",
              "host": ["{{base_url}}"],
              "path": ["api", "tables", ""]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"table_number\": 1,\n  \"table_name\": \"Window Table\"\n}"
            }
          }
        },
        {
          "name": "Get Table Details",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/tables/{{table_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "tables", "{{table_id}}", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Update Table",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/api/tables/{{table_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "tables", "{{table_id}}", ""]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"table_number\": 2,\n  \"table_name\": \"Corner Table\",\n  \"is_active\": true\n}"
            }
          }
        },
        {
          "name": "Toggle Table Active",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/api/tables/{{table_id}}/toggle/",
              "host": ["{{base_url}}"],
              "path": ["api", "tables", "{{table_id}}", "toggle", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get QR Code Image",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/tables/{{table_id}}/qr/",
              "host": ["{{base_url}}"],
              "path": ["api", "tables", "{{table_id}}", "qr", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Regenerate All QR Codes",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/tables/generate-all/",
              "host": ["{{base_url}}"],
              "path": ["api", "tables", "generate-all", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Delete Table",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/tables/{{table_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "tables", "{{table_id}}", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    }
  ]
}